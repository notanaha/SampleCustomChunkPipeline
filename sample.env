# ===== Copy to .env and fill in =====

# ---- Naming ----
# Index name is derived as {NAME_PREFIX}-index (matches 101_knowledge_base.ipynb)
NAME_PREFIX=<name-prefix>

# ---- Azure AI Search ----
AZURE_SEARCH_ENDPOINT=https://<search-service>.search.windows.net
# Optional. If empty, Entra ID (DefaultAzureCredential) is used for data-plane calls.
AZURE_SEARCH_API_KEY=
# Semantic configuration name (must match the one created in 04_create_index)
AZURE_SEARCH_SEMANTIC_CONFIGURATION=<name-prefix>-semantic-configuration

# ---- Azure OpenAI (embeddings + vision verbalization) ----
AZURE_OPENAI_ENDPOINT=https://<foundry>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional. If empty, Entra ID (DefaultAzureCredential) is used for Azure OpenAI.
AZURE_OPENAI_API_KEY=
# Embedding model: text-embedding-3-large -> 3072 dims (must match the index)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_DIMENSIONS=3072
# Vision-capable chat deployment used to verbalize page images
CHAT_DEPLOYMENT=gpt-5.4

# ---- Azure AI Content Understanding (Foundry resource endpoint) ----
# Used by 02_extract_markdown (prebuilt-documentSearch)
AI_SERVICES_SUBDOMAIN_URL=https://<foundry>.services.ai.azure.com
# Optional key. If empty, Entra ID is used.
AI_SERVICES_KEY=

# ---- Blob Storage (page images + source docs; blob_url) ----
# Either a full connection string, or ResourceId=... form for managed identity.
STORAGE_CONNECTION_STRING=
# Storage account blob endpoint, used when authenticating with Entra ID.
STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net
BLOB_CONTAINER_NAME=<blob-container-name>

# ---- Entra ID ----
AZURE_TENANT_ID=<tenant-id>

# ---- Pipeline knobs ----
# Token-based markdown chunking
CHUNK_MAX_TOKENS=8000
CHUNK_OVERLAP_TOKENS=2000
# Filename separator used to encode page numbers, e.g. "myfile@@@01.jpeg"
SEPARATOR_WORD=@@@
# PDF -> image rendering DPI
PDF_IMAGE_DPI=200
